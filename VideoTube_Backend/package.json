{
  "name": "videotube",
  "version": "1.0.0",
  "description": "A Backend centric project from youtube",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "nodemon --delay 3 src/index.js",
    "worker": "node --env-file=.env src/workers/index.js",
    "worker:video": "NODE_OPTIONS='--max-old-space-size=1024' node --env-file=.env src/workers/video.worker.js",
    "worker:embedding": "NODE_OPTIONS='--max-old-space-size=1024' node --env-file=.env src/workers/embedding.worker.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\" \"npm run worker:video\" \"npm run worker:embedding\"",
    "build": "node src/index.js"
  },
  "keywords": [
    "Aftab",
    "Backend",
    "videoTube",
    "udemy"
  ],
  "author": "aftab",
  "license": "ISC",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.4",
    "chalk": "^5.6.2",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.3.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "groq-sdk": "^1.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mailgen": "^2.0.32",
    "mongoose": "^9.2.4",
    "mongoose-aggregate-paginate-v2": "^1.1.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "nodemon": "^3.1.14",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prettier": "^3.8.1",
    "rate-limit-redis": "^5.0.0",
    "tiktoken": "^1.0.22",
    "winston": "^3.19.0"
  }
}
